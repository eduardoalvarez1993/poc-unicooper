{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "package.json",
      "package-lock.json",
      "skills-lock.json",
      "public/**",
      "**/*.log",
      "**/.*",
      ".git/**",
      ".github/**",
      ".agents/**",
      ".firebaserc",
      ".gitignore",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      }
    ]
  }
}
